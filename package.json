{
  "name": "laptop-tycoon",
  "version": "0.1.0",
  "description": "Text-driven laptop company tycoon game",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"yarn dev:renderer\" \"yarn dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "wait-on http://localhost:5173 && tsc -p tsconfig.main.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "tsc -p tsconfig.main.json && vite build",
    "start": "electron .",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "author": "",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^34.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.1.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2"
  }
}
